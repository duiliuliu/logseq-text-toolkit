{
  "disabled": false,
  "theme": "light",
  "language": "zh-CN",
  "toolbar": true,
  "toolbarShortcut": "",
  "useSystemTheme": false,
  "useSystemLanguage": false,
  "showBorder": false,
  "width": "110px",
  "height": "28px",
  "hoverDelay": 500,
  "sponsorEnabled": false,
  "ToolbarItems": [
    {
      "id": "group-custom",
      "label": "Format",
      "icon": "ti ti-format",
      "funcmode": "replace",
      "clickfunc": "",
      "subItems": [
        {
          "id": "wrap-bold",
          "label": "Bold",
          "binding": "",
          "icon": "ti ti-bold",
          "funcmode": "replace",
          "clickfunc": "**${selectedText}**"
        },
        {
          "id": "wrap-italic",
          "label": "Italic",
          "binding": "mod+shift+i",
          "icon": "ti ti-italic",
          "funcmode": "replace",
          "clickfunc": "*${selectedText}*"
        },
        {
          "id": "wrap-strike-through",
          "label": "Strike through",
          "binding": "",
          "icon": "ti ti-strikethrough",
          "funcmode": "replace",
          "clickfunc": "~~${selectedText}~~"
        }
      ]
    },
    {
      "id": "group-hl-custom",
      "label": "Highlight",
      "icon": "ti ti-highlight",
      "funcmode": "replace",
      "clickfunc": "",
      "subItems": [
        {
          "id": "wrap-yellow-hl",
          "label": "Yellow",
          "binding": "",
          "icon": "ti ti-highlight",
          "funcmode": "replace",
          "clickfunc": "==${selectedText}=="
        },
        {
          "id": "wrap-red-hl",
          "label": "Red",
          "binding": "",
          "icon": "ti ti-highlight",
          "funcmode": "replace",
          "clickfunc": "[:mark.red ${selectedText}]"
        },
        {
          "id": "wrap-blue-hl",
          "label": "Blue",
          "binding": "",
          "icon": "ti ti-highlight",
          "funcmode": "replace",
          "clickfunc": "[:mark.blue ${selectedText}]"
        },
        {
          "id": "wrap-green-hl",
          "label": "Green",
          "binding": "",
          "icon": "ti ti-highlight",
          "funcmode": "replace",
          "clickfunc": "[:mark.green ${selectedText}]"
        },
        {
          "id": "wrap-purple-hl",
          "label": "Purple",
          "binding": "",
          "icon": "ti ti-highlight",
          "funcmode": "replace",
          "clickfunc": "[:mark.purple ${selectedText}]"
        }
      ]
    },
    {
      "id": "group-text-color",
      "label": "Text Color",
      "icon": "ti ti-text",
      "funcmode": "replace",
      "clickfunc": "",
      "subItems": [
        {
          "id": "wrap-red-text",
          "label": "Red text",
          "binding": "",
          "icon": "ti ti-text",
          "funcmode": "replace",
          "clickfunc": "[:span.red ${selectedText}]"
        },
        {
          "id": "wrap-blue-text",
          "label": "Blue text",
          "binding": "",
          "icon": "ti ti-text",
          "funcmode": "replace",
          "clickfunc": "[:span.blue ${selectedText}]"
        },
        {
          "id": "wrap-yellow-text",
          "label": "Yellow text",
          "binding": "",
          "icon": "ti ti-text",
          "funcmode": "replace",
          "clickfunc": "[:span.yellow ${selectedText}]"
        },
        {
          "id": "wrap-green-text",
          "label": "Green text",
          "binding": "",
          "icon": "ti ti-text",
          "funcmode": "replace",
          "clickfunc": "[:span.green ${selectedText}]"
        },
        {
          "id": "wrap-purple-text",
          "label": "Purple text",
          "binding": "",
          "icon": "ti ti-text",
          "funcmode": "replace",
          "clickfunc": "[:span.purple ${selectedText}]"
        }
      ]
    },
    {
      "id": "group-text-underline",
      "label": "Underline",
      "icon": "ti ti-underline",
      "funcmode": "replace",
      "clickfunc": "",
      "subItems": [
        {
          "id": "wrap-red-underline",
          "label": "Red underline",
          "binding": "",
          "icon": "ti ti-underline",
          "funcmode": "replace",
          "clickfunc": "[:u.red ${selectedText}]"
        },
        {
          "id": "wrap-blue-underline",
          "label": "Blue underline",
          "binding": "",
          "icon": "ti ti-underline",
          "funcmode": "replace",
          "clickfunc": "[:u.blue ${selectedText}]"
        },
        {
          "id": "wrap-yellow-underline",
          "label": "Yellow underline",
          "binding": "",
          "icon": "ti ti-underline",
          "funcmode": "replace",
          "clickfunc": "[:u.yellow ${selectedText}]"
        },
        {
          "id": "wrap-green-underline",
          "label": "Green underline",
          "binding": "",
          "icon": "ti ti-underline",
          "funcmode": "replace",
          "clickfunc": "[:u.green ${selectedText}]"
        },
        {
          "id": "wrap-purple-underline",
          "label": "Purple underline",
          "binding": "",
          "icon": "ti ti-underline",
          "funcmode": "replace",
          "clickfunc": "[:u.purple ${selectedText}]"
        }
      ]
    },
    {
      "id": "wrap-cloze",
      "label": "Cloze",
      "binding": "",
      "icon": "ti ti-message-circle",
      "funcmode": "replace",
      "clickfunc": "[:span.cloze ${selectedText}]",
      "hidden": true
    },
    {
      "id": "remove-formatting",
      "label": "Remove formatting",
      "binding": "mod+shift+x",
      "icon": "ti ti-eraser",
      "funcmode": "regexReplace",
      "clickfunc": {
        "regex": "\\[:(?:mark|span|u)\\.(?:red|blue|yellow|green|purple)\\s+([^\\]]*)\\]|==([^=]*)==|~~([^~]*)~~|\\*\\*([^\\*]*)\\*\\*|\\*([^\\*]*)\\*|`([^`]*)`",
        "replacement": "$1$2$3$4$5$6"
      },
      "hidden": true
    }
  ]
}
